{
  "name": "trail-vscode",
  "displayName": "Trail Agents",
  "description": "Unified ACP agent chat, review, checkpoint, and apply workflow backed by Trail.",
  "version": "0.1.0",
  "publisher": "trail",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/crabbuild/trail.git",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "agent",
    "ACP",
    "Trail",
    "AI",
    "review"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:trail.tasks",
    "onView:trail.reviews",
    "onView:trail.queue",
    "onCommand:trail.initWorkspace",
    "onCommand:trail.newAgentTask",
    "onCommand:trail.openAgentChat",
    "onCommand:trail.openLatestReview",
    "onCommand:trail.applyLatestDryRun",
    "onCommand:trail.queueMerge",
    "onCommand:trail.explainQueueEntry",
    "onCommand:trail.runMergeQueue",
    "onCommand:trail.removeQueueEntry",
    "onCommand:trail.rewindTask",
    "onCommand:trail.preserveFailedAttempt",
    "onCommand:trail.removeAgentTask",
    "onCommand:trail.runLaneTest",
    "onCommand:trail.runLaneEval",
    "onCommand:trail.openLaneWorkdir",
    "onCommand:trail.compareTasks",
    "onCommand:trail.refreshTasks",
    "onCommand:trail.startDaemon",
    "onCommand:trail.doctor",
    "onCommand:trail.openSettings",
    "onCommand:trail.addAcpProvider",
    "onCommand:trail.askSelection",
    "onCommand:trail.attachSelection",
    "onCommand:trail.showLineHistory",
    "onCommand:trail.showFileChanges"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trailAgents",
          "title": "Trail Agents",
          "icon": "resources/trail.svg"
        }
      ]
    },
    "views": {
      "trailAgents": [
        {
          "id": "trail.tasks",
          "name": "Tasks",
          "type": "tree"
        },
        {
          "id": "trail.reviews",
          "name": "Reviews",
          "type": "tree"
        },
        {
          "id": "trail.queue",
          "name": "Queue",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "trail.initWorkspace",
        "title": "Trail: Initialize Workspace",
        "icon": "$(repo-create)"
      },
      {
        "command": "trail.newAgentTask",
        "title": "Trail: New Agent Task",
        "icon": "$(comment-add)"
      },
      {
        "command": "trail.openAgentChat",
        "title": "Trail: Open Agent Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "trail.openLatestReview",
        "title": "Trail: Open Latest Agent Review",
        "icon": "$(checklist)"
      },
      {
        "command": "trail.applyLatestDryRun",
        "title": "Trail: Apply Latest Agent Task Dry Run",
        "icon": "$(git-pull-request-draft)"
      },
      {
        "command": "trail.queueMerge",
        "title": "Trail: Queue Agent Task Merge",
        "icon": "$(git-merge)"
      },
      {
        "command": "trail.explainQueueEntry",
        "title": "Trail: Explain Merge Queue Entry",
        "icon": "$(question)"
      },
      {
        "command": "trail.runMergeQueue",
        "title": "Trail: Run Merge Queue",
        "icon": "$(run-all)"
      },
      {
        "command": "trail.removeQueueEntry",
        "title": "Trail: Remove Merge Queue Entry",
        "icon": "$(close)"
      },
      {
        "command": "trail.rewindTask",
        "title": "Trail: Rewind Agent Task",
        "icon": "$(debug-reverse-continue)"
      },
      {
        "command": "trail.preserveFailedAttempt",
        "title": "Trail: Preserve Failed Attempt and Rewind",
        "icon": "$(git-branch)"
      },
      {
        "command": "trail.removeAgentTask",
        "title": "Trail: Remove Agent Task",
        "icon": "$(trash)"
      },
      {
        "command": "trail.runLaneTest",
        "title": "Trail: Run Lane Test",
        "icon": "$(beaker)"
      },
      {
        "command": "trail.runLaneEval",
        "title": "Trail: Run Lane Eval",
        "icon": "$(symbol-method)"
      },
      {
        "command": "trail.openLaneWorkdir",
        "title": "Trail: Open Lane Workdir",
        "icon": "$(root-folder-opened)"
      },
      {
        "command": "trail.compareTasks",
        "title": "Trail: Compare Agent Tasks",
        "icon": "$(diff)"
      },
      {
        "command": "trail.refreshTasks",
        "title": "Trail: Refresh Agent Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "trail.startDaemon",
        "title": "Trail: Start Daemon",
        "icon": "$(server-process)"
      },
      {
        "command": "trail.doctor",
        "title": "Trail: Doctor",
        "icon": "$(pulse)"
      },
      {
        "command": "trail.openSettings",
        "title": "Trail: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "trail.addAcpProvider",
        "title": "Trail: Add ACP Provider",
        "icon": "$(plug)"
      },
      {
        "command": "trail.askSelection",
        "title": "Trail: Ask Agent About Selection",
        "icon": "$(comment)"
      },
      {
        "command": "trail.attachSelection",
        "title": "Trail: Attach Selection to Agent Task",
        "icon": "$(link)"
      },
      {
        "command": "trail.showLineHistory",
        "title": "Trail: Show History for Line",
        "icon": "$(history)"
      },
      {
        "command": "trail.showFileChanges",
        "title": "Trail: Show Agent Changes for File",
        "icon": "$(file-code)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "trail.tasks",
        "contents": "Open a folder to use Trail agents.",
        "when": "!trail.workspaceOpen"
      },
      {
        "view": "trail.tasks",
        "contents": "Initialize Trail to record agent tasks, checkpoints, and review state.\n[Initialize workspace](command:trail.initWorkspace)",
        "when": "trail.workspaceOpen && !trail.initialized"
      },
      {
        "view": "trail.tasks",
        "contents": "No agent tasks yet.\n[New agent task](command:trail.newAgentTask)\n[Start daemon](command:trail.startDaemon)",
        "when": "trail.workspaceOpen && trail.initialized"
      },
      {
        "view": "trail.reviews",
        "contents": "No reviewable Trail agent tasks yet.\n[New agent task](command:trail.newAgentTask)",
        "when": "trail.workspaceOpen && trail.initialized"
      },
      {
        "view": "trail.queue",
        "contents": "No queued Trail merges yet.\n[Run merge queue](command:trail.runMergeQueue)",
        "when": "trail.workspaceOpen && trail.initialized"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "trail.initWorkspace",
          "when": "view == trail.tasks && trail.workspaceOpen && !trail.initialized",
          "group": "navigation"
        },
        {
          "command": "trail.refreshTasks",
          "when": "view == trail.tasks || view == trail.reviews || view == trail.queue",
          "group": "navigation"
        },
        {
          "command": "trail.newAgentTask",
          "when": "view == trail.tasks",
          "group": "navigation"
        },
        {
          "command": "trail.openSettings",
          "when": "view == trail.tasks || view == trail.reviews || view == trail.queue",
          "group": "navigation"
        },
        {
          "command": "trail.runMergeQueue",
          "when": "view == trail.queue",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "trail.openAgentChat",
          "when": "viewItem == trailTask",
          "group": "inline"
        },
        {
          "command": "trail.openLatestReview",
          "when": "viewItem == trailTask",
          "group": "inline"
        },
        {
          "command": "trail.rewindTask",
          "when": "viewItem == trailTask",
          "group": "mutation"
        },
        {
          "command": "trail.preserveFailedAttempt",
          "when": "viewItem == trailTask",
          "group": "mutation"
        },
        {
          "command": "trail.removeAgentTask",
          "when": "viewItem == trailTask",
          "group": "destructive"
        },
        {
          "command": "trail.runLaneTest",
          "when": "viewItem == trailTask",
          "group": "gate"
        },
        {
          "command": "trail.runLaneEval",
          "when": "viewItem == trailTask",
          "group": "gate"
        },
        {
          "command": "trail.openLaneWorkdir",
          "when": "viewItem == trailTask",
          "group": "navigation"
        },
        {
          "command": "trail.explainQueueEntry",
          "when": "viewItem == trailQueueEntry",
          "group": "inline"
        },
        {
          "command": "trail.removeQueueEntry",
          "when": "viewItem == trailQueueEntry",
          "group": "destructive"
        }
      ],
      "editor/context": [
        {
          "command": "trail.askSelection",
          "when": "editorHasSelection",
          "group": "trail"
        },
        {
          "command": "trail.showFileChanges",
          "when": "resourceScheme == file",
          "group": "trail"
        }
      ]
    },
    "configuration": {
      "title": "Trail Agents",
      "properties": {
        "trail.path": {
          "type": "string",
          "default": "trail",
          "description": "Path to the Trail CLI executable."
        },
        "trail.defaultProvider": {
          "type": "string",
          "default": "claude-code",
          "description": "Default ACP provider passed to `trail agent acp`. Built-ins include `claude-code` and `codex`; custom provider ids are also allowed."
        },
        "trail.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Start `trail daemon` when no daemon endpoint is discovered."
        },
        "trail.customProviders": {
          "type": "array",
          "default": [],
          "description": "Custom ACP provider launch definitions.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "command"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "compile": "npm run clean && node scripts/esbuild.mjs",
    "check": "tsc --noEmit",
    "test": "npm run check && npm run compile && node scripts/test.mjs",
    "test:extension": "npm run compile && node scripts/extension-test.mjs",
    "package:vsix": "npm run compile && vsce package --no-dependencies",
    "watch": "node scripts/esbuild.mjs --watch",
    "vscode:prepublish": "npm run compile && npm run check"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@pierre/diffs": "^1.2.11",
    "@pierre/trees": "^1.0.0-beta.4",
    "@shadcn/react": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide": "^1.21.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  }
}
